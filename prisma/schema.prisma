// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                    String              @id @default(uuid())
  login                 String?             @unique
  senha                 String?
  email                 String?             @unique
  status                Int                 @default(1)
  passwordResetCode     String?
  passwordResetExpires  DateTime?
  passwordResetAttempts Int                 @default(0)
  permissaoId           String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  RefreshToken          RefreshToken[]
  perfil                Perfil[]
  processos             Processos[]
  rlUsuarioProcesso     RlUsuarioProcesso[]

  permissao Permissoes @relation(fields: [permissaoId], references: [id])

  @@map("usuario")
}

model Permissoes {
  id                 String   @id @default(uuid())
  codigoPermissao    String   @unique
  nomePermissao      String
  descricaoPermissao String
  ativo              Boolean  @default(true)
  tipo               Int      @default(1) // 1-Sistema, 2-Desenvolvimento
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  usuarios Usuario[]

  @@map("permissoes")
}

model Perfil {
  id        String    @id @default(uuid())
  nome      String
  sobrenome String
  telefone  String?
  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  usuarioId String    @unique
  foto      String?
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfil")
}

model RefreshToken {
  id        String  @id @default(uuid())
  usuarioId String
  expiresIn Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

model Clientes {
  id          String      @id @default(uuid())
  nome        String
  documento   String      @unique
  contato     String?
  email       String?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  processos   Processos[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@map("clientes")
}

model Processos {
  id                   String              @id @default(uuid())
  numeroProcesso       String              @unique
  descricao            String
  usuarioCriacaoId     String
  statusId             String
  tipoId               String
  clienteId            String
  status               StatusProcesso      @relation(fields: [statusId], references: [id])
  tipo                 TipoProcesso        @relation(fields: [tipoId], references: [id])
  usuarioCriacao       Usuario             @relation(fields: [usuarioCriacaoId], references: [id])
  usuariosResponsaveis RlUsuarioProcesso[]
  anexosProcesso       AnexosProcesso[]
  cliente              Clientes            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime?           @updatedAt

  @@map("processos")
}

model RlUsuarioProcesso {
  id String @id @default(uuid())

  usuarioId  String
  processoId String

  status    Processos @relation(fields: [processoId], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@map("rlUsuarioProcesso")
}

model StatusProcesso {
  id           String  @id @default(uuid())
  codigoStatus String  @unique
  nomeStatus   String
  ativo        Boolean @default(true)

  processos Processos[]
  createdAt DateTime    @default(now())
  updatedAt DateTime?   @updatedAt

  @@map("statusProcesso")
}

model TipoProcesso {
  id         String  @id @default(uuid())
  codigoTipo String  @unique
  nomeTipo   String
  ativo      Boolean @default(true)

  processos Processos[]
  createdAt DateTime    @default(now())
  updatedAt DateTime?   @updatedAt

  @@map("tipoProcesso")
}

model AnexosProcesso {
  id             String    @id @default(uuid())
  nome           String
  processoId     String
  caminhoArquivo String    @db.VarChar(1024)
  processo       Processos @relation(fields: [processoId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@map("anexosProcesso")
}
