// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                    String                 @id @default(uuid())
  login                 String?                @unique
  senha                 String?
  email                 String?                @unique
  status                Int                    @default(1)
  passwordResetCode     String?
  passwordResetExpires  DateTime?
  passwordResetAttempts Int                    @default(0)
  permissaoId           String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  RefreshToken          RefreshToken[]
  perfil                Perfil?
  processos             Processos[]
  rlUsuarioProcesso     RlUsuarioProcesso[]
  auditLogs             AuditLog[]
  atualizacoes          AtualizacoesProcesso[]
  permissao             Permissoes             @relation(fields: [permissaoId], references: [id])
  notificacoesFeitas    Notificacao[]
  notificacoesRecebidas RlNotificacaoUsuario[]

  @@map("usuario")
}

model Permissoes {
  id                 String   @id @default(uuid())
  codigoPermissao    String   @unique
  nomePermissao      String
  descricaoPermissao String
  ativo              Boolean  @default(true)
  tipo               Int      @default(1) // 1-Sistema, 2-Desenvolvimento
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  usuarios Usuario[]

  @@map("permissoes")
}

model Perfil {
  id        String    @id @default(uuid())
  nome      String
  sobrenome String
  telefone  String?
  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  usuarioId String    @unique
  foto      String?
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfil")
}

model RefreshToken {
  id        String  @id @default(uuid())
  usuarioId String
  expiresIn Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

model Clientes {
  id          String      @id @default(uuid())
  nome        String
  documento   String      @unique
  contato     String?
  email       String?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?
  processos   Processos[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@map("clientes")
}

model Processos {
  id                   String                 @id @default(uuid())
  numeroProcesso       String                 @unique
  descricao            String
  usuarioCriacaoId     String
  statusId             String
  tipoId               String
  clienteId            String
  status               StatusProcesso         @relation(fields: [statusId], references: [id])
  tipo                 TipoProcesso           @relation(fields: [tipoId], references: [id])
  usuarioCriacao       Usuario                @relation(fields: [usuarioCriacaoId], references: [id])
  usuariosResponsaveis RlUsuarioProcesso[]
  anexosProcesso       AnexosProcesso[]
  atualizacoes         AtualizacoesProcesso[]
  notificacoes         Notificacao[]
  prazos               Prazos[]
  cliente              Clientes               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime?              @updatedAt

  @@map("processos")
}

model RlUsuarioProcesso {
  id String @id @default(uuid())

  usuarioId  String
  processoId String

  processo  Processos @relation(fields: [processoId], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@map("rlUsuarioProcesso")
}

model StatusProcesso {
  id           String  @id @default(uuid())
  codigoStatus String  @unique
  nomeStatus   String
  ativo        Boolean @default(true)

  processos    Processos[]
  atualizacoes AtualizacoesProcesso[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime?              @updatedAt

  @@map("statusProcesso")
}

model TipoProcesso {
  id         String  @id @default(uuid())
  codigoTipo String  @unique
  nomeTipo   String
  ativo      Boolean @default(true)

  processos Processos[]
  createdAt DateTime    @default(now())
  updatedAt DateTime?   @updatedAt

  @@map("tipoProcesso")
}

model AnexosProcesso {
  id             String    @id @default(uuid())
  nome           String
  processoId     String
  caminhoArquivo String
  processo       Processos @relation(fields: [processoId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@map("anexosProcesso")
}

enum AcaoLog {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id         String  @id @default(uuid())
  entidade   String // Ex: "PROCESSO", "USUARIO", "CLIENTE"
  entidadeId String // O ID do processo ou usuario afetado
  acao       AcaoLog // CREATE, UPDATE, DELETE
  atorId     String // Quem fez a ação (ID do usuário logado)

  // Usamos JSON para guardar a "fotografia" dos dados
  dadosAnteriores Json? // Como era antes (null se for CREATE)
  dadosNovos      Json? // Como ficou (null se for DELETE)

  createdAt DateTime @default(now())

  // Relacionamento opcional para puxar o nome de quem fez a ação no frontend
  ator Usuario @relation(fields: [atorId], references: [id])

  @@index([entidade, entidadeId]) // Índice para buscas ultra rápidas no banco
  @@map("audit_logs")
}

enum TipoAtualizacaoProcesso {
  PROCESSO_ALTERADO
  ANEXOS
}

model AtualizacoesProcesso {
  id         String                   @id @default(uuid())
  processoId String
  usuarioId  String
  conteudo   String
  statusId   String
  tipo       TipoAtualizacaoProcesso?
  status     StatusProcesso           @relation(fields: [statusId], references: [id])
  usuario    Usuario                  @relation(fields: [usuarioId], references: [id])
  processo   Processos                @relation(fields: [processoId], references: [id], onDelete: Cascade)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@map("atualizacoesProcesso")
}

// Enum opcional para tipar as ações e facilitar no Frontend (mude os valores conforme seu sistema)
enum TipoNotificacao {
  ATUALIZACAO_PROCESSO
  NOVO_ANEXO
  NOVO_PROCESSO
}

model Notificacao {
  id        String          @id @default(uuid())
  tipo      TipoNotificacao
  descricao String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Quem realizou a ação (O Ator)
  usuarioAtorId String
  usuarioAtor   Usuario @relation(fields: [usuarioAtorId], references: [id])

  // O Processo relacionado à notificação (Opcional, pois pode haver notificações gerais)
  processoId String?
  processo   Processos? @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Relação com a tabela intermediária que diz quem vai receber
  destinatarios RlNotificacaoUsuario[]

  @@map("notificacao")
}

// Tabela de relacionamento (Pivot) para controlar o status de leitura por usuário
model RlNotificacaoUsuario {
  id        String    @id @default(uuid())
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  notificacaoId String
  notificacao   Notificacao @relation(fields: [notificacaoId], references: [id], onDelete: Cascade)

  // Garante que o mesmo usuário não receba duas vezes a mesma linha de notificação
  @@unique([usuarioId, notificacaoId])
  // Índice essencial para a query do "sininho" rodar rápido no banco
  @@index([usuarioId, isRead])
  @@map("rl_notificacao_usuario")
}

enum TipoPrazo {
  PETICAO
  AUDIENCIA
  DILIGENCIA
  REUNIAO
  OUTRO
}

enum StatusPrazo {
  PENDENTE
  CONCLUIDO
}

model Prazos {
  id         String      @id @default(uuid())
  titulo     String
  descricao  String
  dataPrazo  DateTime
  processoId String
  status     StatusPrazo @default(PENDENTE)
  tipo       TipoPrazo
  processo   Processos   @relation(fields: [processoId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime?   @updatedAt

  @@map("prazos")
}
